name: inclinati
description: "A new Flutter project."
publish_to: 'none'
version: 1.0.8
environment:
  sdk: ^3.10.0-74.0.dev
dependencies:
  flutter:
    sdk: flutter
  cupertino_icons: ^1.0.8
  sensors_plus: ^7.0.0
  geolocator: ^14.0.2
  shared_preferences: ^2.5.3
  provider: ^6.1.5+1
  flutter_markdown: ^0.6.10
  flutter_reactive_ble: ^5.2.1
  logging: ^1.2.0
dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^6.0.0
flutter:
  uses-material-design: true
  fonts:
    - family: 3270NerdFont
      fonts:
        - asset: fonts/3270NerdFontMono-Condensed.ttf
  assets:
    - CHANGELOG.md
